# MongoDB (local docker instance)
MONGODB_URI=mongodb://localhost:27018/?directConnection=true
MONGODB_DB=hugin_jobs

# DeepSeek (Vercel AI SDK)
DEEPSEEK_API_KEY=
# Exact model id, e.g. deepseek-chat / deepseek-reasoner (set your "v4 flash" id here)
DEEPSEEK_MODEL=deepseek-chat
# How many jobs to judge concurrently per batch (default 5)
JUDGE_CONCURRENCY=5
# How many portals may run at once; 1 = strict serial queue (default 1)
PORTAL_CONCURRENCY=1
# Per-request HTTP timeout in ms (default 30000)
HTTP_TIMEOUT_MS=30000
# Consecutive fetch failures before a portal is auto-disabled (default 3)
MAX_FETCH_FAILURES=3

# Dry-run/testing flags (normally leave off)
# HUGIN_DRY_RUN=1              # no Mongo job/portal writes and no Telegram sends
# HUGIN_DRY_RUN_SKIP_LLM=1     # with dry-run, fetch/dedup only; do not judge
# HUGIN_RUN_ONCE=1             # run enabled portals once and exit
# HUGIN_PORTAL=google          # optional comma-separated source/name filter for one portal

# Admin dashboard (React API + JWT auth)
# Port to listen on. On Render/PaaS leave this unset — the platform injects PORT.
ADMIN_PORT=4000
# Secret used to sign admin JWTs — set a long random value in production
JWT_SECRET=
# Token lifetime (any jsonwebtoken expiresIn value, e.g. 7d, 12h). Default 7d.
# JWT_EXPIRES_IN=7d
# Comma-separated origins allowed to call the API cross-site (the frontend URL,
# e.g. https://your-app.web.app). Leave empty when the API also serves the UI.
# ADMIN_CORS_ORIGIN=https://your-app.web.app
# The two (and only two) admin accounts, seeded by `npm run seed:admins`
ADMIN1_USER=
ADMIN1_PASS=
ADMIN2_USER=
ADMIN2_PASS=

# Telegram notifications (seeded subscribers)
TELEGRAM_BOT_TOKEN=
# Comma-separated chat ids
TELEGRAM_CHAT_IDS=
