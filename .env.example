# MongoDB (local docker instance)
MONGODB_URI=mongodb://localhost:27018/?directConnection=true
MONGODB_DB=hugin_jobs

# DeepSeek (Vercel AI SDK)
DEEPSEEK_API_KEY=
# Exact model id, e.g. deepseek-chat / deepseek-reasoner (set your "v4 flash" id here)
DEEPSEEK_MODEL=deepseek-chat
# How many jobs to judge concurrently per batch (default 5)
JUDGE_CONCURRENCY=5
# Per-request HTTP timeout in ms (default 30000)
HTTP_TIMEOUT_MS=30000
# Consecutive fetch failures before a portal is auto-disabled (default 3)
MAX_FETCH_FAILURES=3

# Telegram notifications (seeded subscribers)
TELEGRAM_BOT_TOKEN=
# Comma-separated chat ids
TELEGRAM_CHAT_IDS=
